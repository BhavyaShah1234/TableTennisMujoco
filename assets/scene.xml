        <joint name="fr3_joint1" type="hinge" axis="0 0 1" range="-2.9007 2.9007" damping="1" frictionloss="0.1"/>
        <geom type="mesh" mesh="link1_mesh" material="robot_white" contype="0" conaffinity="0" group="0"/>
        <body name="fr3_link2" pos="0 0 0" quat="0.707107 -0.707107 0 0">
          <inertial pos="-0.0006 0.0503 0.0691" mass="2.7402" diaginertia="0.01 0.0098 0.0088"/>
          <joint name="fr3_joint2" type="hinge" axis="0 0 1" range="-1.8326 1.8326" damping="1" frictionloss="0.1"/>
