          <body name="fr3_link3" pos="0 -0.316 0" quat="0.707107 0.707107 0 0">
            <inertial pos="0.0269 0.0387 -0.0738" mass="2.3883" diaginertia="0.0079 0.0068 0.0073"/>
            <joint name="fr3_joint3" type="hinge" axis="0 0 1" range="-2.9007 2.9007" damping="1" frictionloss="0.1"/>
            <geom type="mesh" mesh="link3_mesh" material="robot_white" contype="0" conaffinity="0" group="0"/>
            <body name="fr3_link4" pos="0.0825 0 0" quat="0.707107 0.707107 0 0">
              <inertial pos="-0.0532 0.0459 0.0227" mass="2.3883" diaginertia="0.0079 0.0068 0.0073"/>
              <joint name="fr3_joint4" type="hinge" axis="0 0 1" range="-3.0718 -0.0698" damping="1" frictionloss="0.1"/>
              <geom type="mesh" mesh="link4_mesh" material="robot_white" contype="0" conaffinity="0" group="0"/>
              <body name="fr3_link5" pos="-0.0825 0.384 0" quat="0.707107 -0.707107 0 0">
                <inertial pos="0.0001 -0.0614 0.0304" mass="2.7337" diaginertia="0.0136 0.0114 0.0049"/>
                <joint name="fr3_joint5" type="hinge" axis="0 0 1" range="-2.8774 2.8774" damping="0.5" frictionloss="0.1"/>
                <geom type="mesh" mesh="link5_mesh" material="robot_white" contype="0" conaffinity="0" group="0"/>
                <body name="fr3_link6" pos="0 0 0" quat="0.707107 0.707107 0 0">
                  <inertial pos="0.0511 0.0094 0.0009" mass="1.6667" diaginertia="0.0024 0.0021 0.0021"/>
                  <joint name="fr3_joint6" type="hinge" axis="0 0 1" range="-0.0175 3.7525" damping="0.5" frictionloss="0.1"/>
                  <geom type="mesh" mesh="link6_mesh" material="robot_white" contype="0" conaffinity="0" group="0"/>
                  <body name="fr3_link7" pos="0.088 0 0" quat="0.707107 0.707107 0 0">
                    <inertial pos="0.0099 0.0099 0.0235" mass="0.7355" fullinertia="0.0015 0.0014 0.0005 0.0001 0.0001 0.0001"/>
                    <joint name="fr3_joint7" type="hinge" axis="0 0 1" range="-3.0543 3.0543" damping="0.5" frictionloss="0.1"/>
                    <geom type="mesh" mesh="link7_mesh" contype="0" conaffinity="0" group="0"/>
                    <body name="fr3_link8" pos="0 0 0.107">
                      <inertial pos="0 0 0" mass="0.01" diaginertia="0.001 0.001 0.001"/>
                      <body name="paddle" pos="0 0 0.157" quat="1 0 0 0">
                        <inertial pos="0 0 0" mass="0.09" fullinertia="0.0002 0.0002 0.00005 0 0 0"/>
                        <!-- <geom type="mesh" mesh="paddle_mesh" pos="0 0 -0.05" quat="0.707107 0 0.707107 0" material="paddle_red" contype="1" conaffinity="1" group="0"/> -->
                        <!-- euler="1.5708 0 0" = Rx(90°): maps STL-Y (long axis, handle at -Y)
                             to body-Z so the handle points toward link7 (body -Z direction).
                             STL-Z (blade face normal) maps to body -Y, so face normal = body -Y. -->
                        <geom type="mesh" mesh="paddle_mesh" pos="0 0 0" euler="1.5708 0 0" material="paddle_red" contype="0" conaffinity="0" group="0"/>
                        <!-- Blade box: thin in Y (= face-normal direction, body -Y).
                             Z extent covers blade impact area along arm axis. -->
                        <geom name="paddle_blade" type="box" size="0.0785 0.00325 0.076" pos="0 0 0" friction="0.8 0.005 0.0001" contype="1" conaffinity="1" group="3" rgba="0.8 0.1 0.1 0.8"/>
                        <geom name="paddle_handle" type="cylinder" size="0.0125 0.05" pos="0 0 -0.075" friction="0.8 0.005 0.0001" contype="1" conaffinity="1" group="3" rgba="0.6 0.4 0.2 1"/>
                        <site name="paddle_contact" pos="0 0 0" size="0.01" rgba="0 1 0 0.3"/>
                        <!-- paddle_normal is 1 cm in body -Y: face normal = body -Y direction,
                             perpendicular to the visual mesh blade face after the euler rotation. -->
                        <site name="paddle_normal" pos="0 -0.01 0" size="0.005" rgba="0 0 1 0.5"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- TABLE TENNIS BALL – initial pos is overridden by set_ball_state() at reset -->
    <body name="ball" pos="-1.0 0 1.5">
      <freejoint/>
      <inertial pos="0 0 0" mass="0.0027" diaginertia="0.000000216 0.000000216 0.000000216"/>
      <!-- solref: [timeconst, dampratio] – low damratio = elastic bounce -->
      <!-- solimp: [dmin, dmax, width] – high dmax = hard surface -->
      <geom name="ball_geom" type="sphere" size="0.020" material="ball_white"
            contype="1" conaffinity="1"
            solref="0.002 0.3" solimp="0.95 0.99 0.001" condim="4"
            friction="0.6 0.005 0.0001"/>
    </body>

    <!-- Cameras -->
    <camera name="main_view" pos="3 -1.5 1.5" xyaxes="0.5 0.866 0 0.354 -0.204 0.913"/>
    <camera name="side_view" pos="0 -4 1.2" xyaxes="1 0 0 0 0.3 1"/>
    <camera name="top_view" pos="0 0 5" xyaxes="1 0 0 0 1 0"/>
    <camera name="robot_view" pos="2.5 0 1.2" xyaxes="0 1 0 -0.3 0 1"/>
  </worldbody>
  
