<mujoco model="table_tennis_scene">
  <compiler angle="radian" meshdir="meshes" autolimits="true"/>

  <option timestep="0.001" integrator="implicitfast" iterations="100" solver="Newton" tolerance="1e-10">
    <flag gravity="enable" contact="enable"/>
  </option>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
    <map stiffness="100" shadowscale="0.5" fogstart="10" fogend="15" zfar="50"/>
    <scale forcewidth="0.05" contactwidth="0.2" contactheight="0.05" connect="0.2" com="0.3" camera="0.5" light="0.5" selectpoint="0.05" jointlength="0.5" jointwidth="0.1" actuatorlength="0.5" actuatorwidth="0.2"/>
  </visual>
  
  <asset>
    <!-- FR3 Robot Meshes -->
    <mesh name="link0_mesh" file="link0.stl"/>
    <mesh name="link1_mesh" file="link1.stl"/>
    <mesh name="link2_mesh" file="link2.stl"/>
    <mesh name="link3_mesh" file="link3.stl"/>
    <mesh name="link4_mesh" file="link4.stl"/>
    <mesh name="link5_mesh" file="link5.stl"/>
    <mesh name="link6_mesh" file="link6.stl"/>
    <mesh name="link7_mesh" file="link7.stl"/>
    <mesh name="paddle_mesh" file="table_tennis_racket.stl" scale="0.0023 0.0023 0.0023"/>
    
    <!-- Materials -->
    <material name="robot_white" rgba="0.9 0.9 0.9 1"/>
    <material name="robot_gray" rgba="0.5 0.5 0.5 1"/>
    <material name="paddle_red" rgba="0.8 0.1 0.1 1"/>
    <material name="table_blue" rgba="0.15 0.25 0.6 1"/>
    <material name="table_dark" rgba="0.1 0.1 0.1 1"/>
    <material name="net_black" rgba="0.05 0.05 0.05 1"/>
    <material name="ball_white" rgba="1 1 1 1"/>
    <material name="floor_mat" rgba="0.4 0.4 0.4 1"/>
    <texture name="floor_tex" type="2d" builtin="checker" rgb1="0.3 0.3 0.3" rgb2="0.4 0.4 0.4" width="512" height="512" mark="edge" markrgb="0.5 0.5 0.5"/>
    <material name="floor_mat_tex" texture="floor_tex" texrepeat="10 10" specular="0.1" shininess="0.1"/>
  </asset>
  
  <worldbody>
    <!-- Lighting -->
    <light name="top_light" pos="0 0 4" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" directional="false" castshadow="true"/>
    <light name="side_light_1" pos="3 0 2" dir="-1 0 -0.5" diffuse="0.5 0.5 0.5" specular="0.1 0.1 0.1"/>
    <light name="side_light_2" pos="-3 0 2" dir="1 0 -0.5" diffuse="0.5 0.5 0.5" specular="0.1 0.1 0.1"/>
    
    <!-- Ground plane -->
    <geom name="floor" type="plane" size="10 10 0.1" material="floor_mat_tex" friction="0.8 0.005 0.0001" solref="0.002 1.0" solimp="0.90 0.95 0.001" condim="4"/>
    
    <!-- TABLE TENNIS TABLE -->
    <body name="table" pos="0 0 0.76">
      <geom name="table_top" type="box" size="1.37 0.7625 0.0125" pos="0 0 0" friction="0.45 0.005 0.0001" solref="0.001 1.0" solimp="0.999 0.999 0.001" condim="4" material="table_blue" mass="50" contype="1" conaffinity="1"/>
      <geom name="center_line" type="box" size="1.37 0.001 0.0126" pos="0 0 0" rgba="1 1 1 1" contype="0" conaffinity="0"/>
      <geom name="end_line_1" type="box" size="0.001 0.7625 0.0126" pos="1.37 0 0" rgba="1 1 1 1" contype="0" conaffinity="0"/>
      <geom name="end_line_2" type="box" size="0.001 0.7625 0.0126" pos="-1.37 0 0" rgba="1 1 1 1" contype="0" conaffinity="0"/>
      <geom name="side_line_1" type="box" size="1.37 0.001 0.0126" pos="0 0.7625 0" rgba="1 1 1 1" contype="0" conaffinity="0"/>
      <geom name="side_line_2" type="box" size="1.37 0.001 0.0126" pos="0 -0.7625 0" rgba="1 1 1 1" contype="0" conaffinity="0"/>
      
      <!-- Net with capsule mesh.  Net body origin sits AT the table top surface
           (pos z=0.0125 = table_top half-thickness in table-body frame), so that:
             world z of net bottom = 0.76 + 0.0125 = 0.7725 m  (table surface)
             world z of net top    = 0.7725 + 0.1525 = 0.9250 m  (standard 15.25 cm height)
      -->
      <body name="net" pos="0 0 0.0125">
        <!-- Vertical net strands (visual only) -->
        <geom name="net_v0" type="capsule" size="0.0008" fromto="0 -0.915 0 0 -0.915 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v1" type="capsule" size="0.0008" fromto="0 -0.76 0 0 -0.76 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v2" type="capsule" size="0.0008" fromto="0 -0.61 0 0 -0.61 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v3" type="capsule" size="0.0008" fromto="0 -0.46 0 0 -0.46 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v4" type="capsule" size="0.0008" fromto="0 -0.305 0 0 -0.305 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v5" type="capsule" size="0.0008" fromto="0 -0.15 0 0 -0.15 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v6" type="capsule" size="0.0008" fromto="0 0 0 0 0 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v7" type="capsule" size="0.0008" fromto="0 0.15 0 0 0.15 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v8" type="capsule" size="0.0008" fromto="0 0.305 0 0 0.305 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v9" type="capsule" size="0.0008" fromto="0 0.46 0 0 0.46 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v10" type="capsule" size="0.0008" fromto="0 0.61 0 0 0.61 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v11" type="capsule" size="0.0008" fromto="0 0.76 0 0 0.76 0.1525" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_v12" type="capsule" size="0.0008" fromto="0 0.915 0 0 0.915 0.1525" material="net_black" contype="0" conaffinity="0"/>
        
        <!-- Horizontal net strands (visual only) -->
        <geom name="net_h0" type="capsule" size="0.0008" fromto="0 -0.915 0.02 0 0.915 0.02" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_h1" type="capsule" size="0.0008" fromto="0 -0.915 0.04 0 0.915 0.04" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_h2" type="capsule" size="0.0008" fromto="0 -0.915 0.06 0 0.915 0.06" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_h3" type="capsule" size="0.0008" fromto="0 -0.915 0.08 0 0.915 0.08" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_h4" type="capsule" size="0.0008" fromto="0 -0.915 0.10 0 0.915 0.10" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_h5" type="capsule" size="0.0008" fromto="0 -0.915 0.12 0 0.915 0.12" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_h6" type="capsule" size="0.0008" fromto="0 -0.915 0.14 0 0.915 0.14" material="net_black" contype="0" conaffinity="0"/>
        <geom name="net_h7" type="capsule" size="0.0015" fromto="0 -0.915 0.1525 0 0.915 0.1525" material="net_black" contype="0" conaffinity="0"/>
        
        <!-- Collision geometries for net -->
        <geom name="net_collision" type="box" size="0.01 0.915 0.07625" pos="0 0 0.07625" friction="0.5 0.005 0.0001" solref="0.003 0.8" solimp="0.75 0.95 0.001" condim="4" contype="1" conaffinity="1" rgba="0.05 0.05 0.05 0.2"/>
        <!-- Top edge as capsule to prevent ball from resting on it -->
        <geom name="net_top_edge" type="capsule" size="0.008" fromto="0 -0.915 0.1525 0 0.915 0.1525" friction="0.3 0.005 0.0001" solref="0.002 0.5" solimp="0.7 0.9 0.001" condim="4" contype="1" conaffinity="1" rgba="0.05 0.05 0.05 0.3"/>
        
        <!-- Net posts (visual only) -->
        <geom name="net_post_1" type="cylinder" size="0.01 0.08625" pos="0 0.925 0" material="table_dark" mass="0.2" contype="0" conaffinity="0"/>
        <geom name="net_post_2" type="cylinder" size="0.01 0.08625" pos="0 -0.925 0" material="table_dark" mass="0.2" contype="0" conaffinity="0"/>
        <geom name="net_tape" type="box" size="0.006 0.915 0.008" pos="0 0 0.07625" rgba="1 1 1 1" contype="0" conaffinity="0"/>
      </body>
      
      <!-- Table legs -->
      <geom name="leg_1" type="box" size="0.025 0.025 0.38" pos="1.2 0.65 -0.38" material="table_dark" mass="2"/>
      <geom name="leg_2" type="box" size="0.025 0.025 0.38" pos="1.2 -0.65 -0.38" material="table_dark" mass="2"/>
      <geom name="leg_3" type="box" size="0.025 0.025 0.38" pos="-1.2 0.65 -0.38" material="table_dark" mass="2"/>
      <geom name="leg_4" type="box" size="0.025 0.025 0.38" pos="-1.2 -0.65 -0.38" material="table_dark" mass="2"/>
      <geom name="frame_long_1" type="box" size="1.2 0.02 0.02" pos="0 0.65 -0.38" material="table_dark" mass="1"/>
      <geom name="frame_long_2" type="box" size="1.2 0.02 0.02" pos="0 -0.65 -0.38" material="table_dark" mass="1"/>
      <geom name="frame_short_1" type="box" size="0.02 0.65 0.02" pos="1.2 0 -0.38" material="table_dark" mass="0.5"/>
      <geom name="frame_short_2" type="box" size="0.02 0.65 0.02" pos="-1.2 0 -0.38" material="table_dark" mass="0.5"/>
    </body>
    
    <!-- FRANKA FR3 ROBOT -->
    <body name="fr3_link0" pos="1.5 0 0.76" quat="0 0 0 1">
      <inertial pos="-0.0172 0.0004 0.0745" mass="2.3966" diaginertia="0.009 0.0115 0.0085"/>
      <geom type="mesh" mesh="link0_mesh" material="robot_white" contype="0" conaffinity="0" group="0"/>
      <body name="fr3_link1" pos="0 0 0.333">
