    <velocity name="vel_joint5" joint="fr3_joint5" kv="10" ctrlrange="-5.26 5.26" forcerange="-87 87"/>
    <velocity name="vel_joint6" joint="fr3_joint6" kv="10" ctrlrange="-4.18 4.18" forcerange="-87 87"/>
