    <jointpos name="joint4_pos" joint="fr3_joint4"/>
    <jointpos name="joint5_pos" joint="fr3_joint5"/>
    <jointpos name="joint6_pos" joint="fr3_joint6"/>
    <jointpos name="joint7_pos" joint="fr3_joint7"/>
